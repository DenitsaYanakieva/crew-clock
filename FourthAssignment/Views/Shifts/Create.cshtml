@model FourthAssignment.Models.ShiftFormViewModel

@{
    ViewData["Title"] = "Create Shift";
}

<h2>Create Shift</h2>
<p>Employee: <strong>@Model.EmployeeName</strong> &mdash; Date: <strong>@Model.Date.ToString("dd MMM yyyy (ddd)")</strong></p>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create" asp-controller="Shifts" method="post" class="col-md-6">
    <input type="hidden" asp-for="EmployeeId" />
    <input type="hidden" asp-for="EmployeeName" />
    <input type="hidden" asp-for="Date" value="@Model.Date.ToString("yyyy-MM-dd")" />

    <div class="mb-3">
        <label asp-for="RoleId" class="form-label">Role</label>
        <select asp-for="RoleId" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.AvailableRoles, "Id", "Name"))" class="form-select">
            <option value="">-- Select Role --</option>
        </select>
        <span asp-validation-for="RoleId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartTime" class="form-label">Start Time</label>
        <input asp-for="StartTime" type="time" class="form-control" />
        <span asp-validation-for="StartTime" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndTime" class="form-label">End Time</label>
        <input asp-for="EndTime" type="time" class="form-control" />
        <span asp-validation-for="EndTime" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Cancel</a>
</form>
